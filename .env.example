# ---- Server ----
PORT=3001
# Comma-separated allowed origins (your local frontend + Netlify URL)
CORS_ORIGIN=http://localhost:5173,https://your-frontend.netlify.app

# ---- Render Postgres ----
# Use the "External Database URL" from your Render Postgres instance.
DATABASE_URL=postgres://user:password@host:5432/dbname
# Set to "false" only if connecting without SSL (e.g. some internal URLs)
DATABASE_SSL=true

# ---- Clerk ----
# From Clerk dashboard -> API keys. The Express SDK reads these automatically.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# ---- Phone normalization ----
# Default country for parsing roster numbers entered without a country code.
# US, AU, GB, etc.
DEFAULT_COUNTRY=US
